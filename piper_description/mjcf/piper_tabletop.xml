<mujoco model="piper_tabletop">
  <compiler angle="radian" meshdir="../meshes/" eulerseq="XYZ" />

  <option gravity="0 0 -9.81" timestep="0.002" />

  <default>
    <joint damping="10" armature="0.1" />
    <geom rgba="0.79 0.82 0.93 1" />
    <position kp="200" kv="20" />
  </default>

  <asset>
    <mesh name="base_link" file="base_link.STL" />
    <mesh name="link1" file="link1.STL" />
    <mesh name="link2" file="link2.STL" />
    <mesh name="link3" file="link3.STL" />
    <mesh name="link4" file="link4.STL" />
    <mesh name="link5" file="link5.STL" />
    <mesh name="link6" file="link6.STL" />
    <mesh name="gripper_base" file="gripper_base.STL" />
    <mesh name="link7" file="link7.STL" />
    <mesh name="link8" file="link8.STL" />
    <texture type="2d" name="groundplane" builtin="checker" rgb1="0.35 0.35 0.35" rgb2="0.25 0.25 0.25" width="512" height="512" />
    <material name="groundplane" texture="groundplane" texrepeat="5 5" />
    <texture type="2d" name="wood" builtin="flat" rgb1="0.65 0.45 0.25" width="64" height="64" />
    <material name="wood" texture="wood" />
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" directional="true" />
    <light pos="1 1 2" dir="-0.5 -0.5 -1" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" />
    <geom type="plane" size="2 2 0.01" material="groundplane" />

    <!-- Piper arm at origin (must appear before freejoint bodies for qpos ordering) -->
    <body name="base_link" pos="0 0 0" gravcomp="1">
      <inertial pos="-0.00474 0.0000257 0.04145" mass="1.02"
                diaginertia="0.00267 0.00283 0.000896" />
      <geom type="mesh" mesh="base_link" />

      <body name="link1" pos="0 0 0.123" gravcomp="1">
        <inertial pos="0.000122 0.000105 -0.00439" mass="0.71"
                  diaginertia="0.000489 0.000405 0.00044" />
        <joint name="joint1" type="hinge" axis="0 0 1" range="-2.618 2.168" />
        <geom type="mesh" mesh="link1" />

        <body name="link2" euler="1.5708 -0.1359 -3.1416" gravcomp="1">
          <inertial pos="0.1987 -0.01093 0.00142" mass="1.17"
                    diaginertia="0.0679 0.0677 0.00117" />
          <joint name="joint2" type="hinge" axis="0 0 1" range="0 3.14" />
          <geom type="mesh" mesh="link2" />

          <body name="link3" pos="0.28503 0 0" euler="0 0 -1.7939" gravcomp="1">
            <inertial pos="-0.02027 -0.13391 -0.000459" mass="0.5"
                      diaginertia="0.01362 0.01380 0.00045" />
            <joint name="joint3" type="hinge" axis="0 0 1" range="-2.967 0" />
            <geom type="mesh" mesh="link3" />

            <body name="link4" pos="-0.021984 -0.25075 0" euler="1.5708 0 0" gravcomp="1">
              <inertial pos="-0.0000967 0.000876 -0.00497" mass="0.38"
                        diaginertia="0.000190 0.000185 0.000155" />
              <joint name="joint4" type="hinge" axis="0 0 1" range="-1.745 1.745" />
              <geom type="mesh" mesh="link4" />

              <body name="link5" euler="-1.5708 0 0" gravcomp="1">
                <inertial pos="-0.0000411 -0.05665 -0.00372" mass="0.383"
                          diaginertia="0.00166 0.00164 0.000185" />
                <joint name="joint5" type="hinge" axis="0 0 1" range="-1.22 1.22" />
                <geom type="mesh" mesh="link5" />

                <body name="link6" pos="0.000088259 -0.091 0" euler="1.5708 0 0" gravcomp="1">
                  <inertial pos="-0.0000883 0.00000906 -0.002" mass="0.007"
                            diaginertia="0.00000107 0.000000573 0.000000573" />
                  <joint name="joint6" type="hinge" axis="0 0 1" range="-2.0944 2.0944" />
                  <geom type="mesh" mesh="link6" rgba="0.90 0.92 0.93 1" />

                  <body name="gripper_base" gravcomp="1">
                    <inertial pos="-0.000184 0.0000805 0.03214" mass="0.45"
                              diaginertia="0.000929 0.000714 0.000394" />
                    <geom type="mesh" mesh="gripper_base" />
                    <site name="ee_site" pos="0 0 0.1358" size="0.001" rgba="0 0 0 0" />

                    <body name="link7" pos="0 0 0.1358" euler="1.5708 0 0" gravcomp="1">
                      <inertial pos="0.000651 -0.04919 0.00972" mass="0.025"
                                diaginertia="0.0000747 0.0000737 0.0000747" />
                      <joint name="joint7" type="slide" axis="0 0 1" range="0 0.035" />
                      <geom type="mesh" mesh="link7" friction="2 0.5 0.01" />
                    </body>

                    <body name="link8" pos="0 0 0.1358" euler="1.5708 0 -3.1416" gravcomp="1">
                      <inertial pos="0.000651 -0.04919 0.00972" mass="0.025"
                                diaginertia="0.0000747 0.0000737 0.0000747" />
                      <joint name="joint8" type="slide" axis="0 0 -1" range="-0.035 0" />
                      <geom type="mesh" mesh="link8" friction="2 0.5 0.01" />
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Table in front of the arm -->
    <body name="table" pos="0.35 0 0">
      <geom name="tabletop" type="box" size="0.2 0.25 0.005" pos="0 0 0.1"
            rgba="0.65 0.45 0.25 1" material="wood" />
      <geom name="leg1" type="cylinder" size="0.015 0.05" pos="0.17 0.22 0.05" rgba="0.5 0.35 0.2 1" />
      <geom name="leg2" type="cylinder" size="0.015 0.05" pos="-0.17 0.22 0.05" rgba="0.5 0.35 0.2 1" />
      <geom name="leg3" type="cylinder" size="0.015 0.05" pos="0.17 -0.22 0.05" rgba="0.5 0.35 0.2 1" />
      <geom name="leg4" type="cylinder" size="0.015 0.05" pos="-0.17 -0.22 0.05" rgba="0.5 0.35 0.2 1" />
    </body>

    <!-- Graspable cube on the table -->
    <body name="cube" pos="0.35 0.08 0.12">
      <freejoint name="cube_joint" />
      <geom name="cube_geom" type="box" size="0.02 0.02 0.02" mass="0.05"
            rgba="0.9 0.2 0.2 1" friction="1.5 0.5 0.01" />
    </body>

    <!-- Place target zone (visual only) -->
    <body name="place_zone" pos="0.35 -0.1 0.101">
      <geom name="zone" type="cylinder" size="0.04 0.001"
            rgba="0.2 0.8 0.2 0.4" contype="0" conaffinity="0" />
    </body>
  </worldbody>

  <!-- Weld constraint to hold cube in gripper (activated by script) -->
  <equality>
    <weld name="grasp" body1="gripper_base" body2="cube" active="false"
          relpose="0 0 0.1358 1 0 0 0" solref="0.01 1" />
  </equality>

  <keyframe>
    <!-- 8 arm joints + 7 cube freejoint (pos xyz + quat wxyz) = 15 qpos -->
    <key name="home" qpos="0 1.57 -1.57 0 0 0 0.015 -0.015  0.35 0.08 0.12 1 0 0 0"
         ctrl="0 1.57 -1.57 0 0 0 0.015 -0.015" />
  </keyframe>

  <actuator>
    <position name="act_joint1" joint="joint1" />
    <position name="act_joint2" joint="joint2" />
    <position name="act_joint3" joint="joint3" />
    <position name="act_joint4" joint="joint4" />
    <position name="act_joint5" joint="joint5" />
    <position name="act_joint6" joint="joint6" />
    <position name="act_joint7" joint="joint7" ctrlrange="0 0.035" kp="400" />
    <position name="act_joint8" joint="joint8" ctrlrange="-0.035 0" kp="400" />
  </actuator>
</mujoco>
